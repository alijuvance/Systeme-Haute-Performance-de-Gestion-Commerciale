// Modèle de données Prisma pour l'ERP/CRM

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// SECURITE & UTILISATEURS
// ==========================================
model Role {
  id          String   @id @default(uuid())
  name        String   @unique // ex: ADMIN, MANAGER, CASHIER, STOREKEEPER
  permissions String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String
  fullName       String
  isActive       Boolean         @default(true)
  resetOtp       String?
  resetOtpExpiresAt DateTime?
  roleId             String
  role               Role            @relation(fields: [roleId], references: [id])
  stockMovements     StockMovement[]
  transfersDispatched StockTransfer[] @relation("DispatchedBy")
  transfersReceived   StockTransfer[] @relation("ReceivedBy")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

// ==========================================
// REFERENTIEL PRODUITS
// ==========================================
model Category {
  id            String     @id @default(uuid())
  name          String     @unique
  parentId      String?
  parent        Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subcategories Category[] @relation("CategoryHierarchy")
  products      Product[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Product {
  id             String          @id @default(uuid())
  sku            String          @unique // Ref interne
  barcode        String?         @unique // Code-barre
  name           String
  description    String?
  defaultPrice   Float // Prix de vente par défaut
  costPrice      Float // PAMP (Prix moyen pondéré)
  isActive       Boolean         @default(true)
  categoryId     String
  category       Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  units          Unit[]
  stockLevels    StockLevel[]
  stockMovements StockMovement[]
  stockTransfers     StockTransfer[]
  purchaseOrderLines PurchaseOrderLine[]
  invoiceLines       InvoiceLine[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Unit {
  id             String   @id @default(uuid())
  name           String // Ex: Pièce, Carton
  conversionRate Float // Ratio par rapport à l'unité de base
  isBaseUnit     Boolean  @default(false)
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ==========================================
// LOGISTIQUE ET STOCKS
// ==========================================
model Depot {
  id               String          @id @default(uuid())
  name             String
  location         String?
  type             String // CENTRAL, RETAIL, WHOLESALE
  stockLevels      StockLevel[]
  movements        StockMovement[]
  transfersFrom    StockTransfer[] @relation("TransferFrom")
  transfersTo      StockTransfer[] @relation("TransferTo")
  purchaseOrders   PurchaseOrder[]
  invoices         Invoice[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model StockLevel {
  id               String   @id @default(uuid())
  quantity         Float    @default(0)
  minAlertQuantity Float    @default(0)
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  depotId          String
  depot            Depot    @relation(fields: [depotId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([productId, depotId]) // Un seul enregistrement de niveau par produit et par dépôt
}

model StockMovement {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  type            String // IN, OUT, TRANSFER_OUT, TRANSFER_IN
  reference       String? // Motif ou ID doc source
  quantityChanged Float // Positif ou négatif
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  depotId         String
  depot           Depot    @relation(fields: [depotId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}

model StockTransfer {
  id              String    @id @default(uuid())
  reference       String    @unique
  status          String    @default("IN_TRANSIT") // IN_TRANSIT, COMPLETED, CANCELLED
  quantity        Float
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromDepotId     String
  fromDepot       Depot     @relation("TransferFrom", fields: [fromDepotId], references: [id], onDelete: Cascade)
  toDepotId       String
  toDepot         Depot     @relation("TransferTo", fields: [toDepotId], references: [id], onDelete: Cascade)
  dispatchedAt    DateTime  @default(now())
  receivedAt      DateTime?
  dispatchedById  String
  dispatchedBy    User      @relation("DispatchedBy", fields: [dispatchedById], references: [id])
  receivedById    String?
  receivedBy      User?     @relation("ReceivedBy", fields: [receivedById], references: [id])
}

// ==========================================
// ACHATS ET FOURNISSEURS (B2B)
// ==========================================
model Supplier {
  id             String          @id @default(uuid())
  name           String
  contactName    String?
  email          String?
  phone          String?
  address        String?
  taxId          String? // NIF/STAT
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PurchaseOrder {
  id               String              @id @default(uuid())
  orderNumber      String              @unique
  date             DateTime            @default(now())
  expectedDate     DateTime?
  status           String              @default("DRAFT") // DRAFT, SENT, RECEIVED, CANCELLED
  totalAmount      Float               @default(0) // Ariary
  amountPaid       Float               @default(0) // Ariary (Ce qu'on a déjà payé au fournisseur)
  supplierId       String
  supplier         Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  receivingDepotId String?           // Dépôt choisi lors de la réception
  receivingDepot   Depot?              @relation(fields: [receivingDepotId], references: [id], onDelete: Cascade)
  lines            PurchaseOrderLine[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model PurchaseOrderLine {
  id              String        @id @default(uuid())
  quantity        Float
  unitPrice       Float         // Prix d'achat unitaire (Ariary)
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ==========================================
// VENTES ET CLIENTS (B2B & POS)
// ==========================================
model Customer {
  id          String    @id @default(uuid())
  type        String    @default("B2C") // B2B, B2C
  companyName String?
  fullName    String?
  phone       String?
  email       String?
  address     String?
  taxId       String? // Matricule fiscal
  creditLimit Float     @default(0)
  currentDebt Float     @default(0)
  invoices    Invoice[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  date          DateTime      @default(now())
  dueDate       DateTime?
  type          String        @default("B2B") // B2B, POS
  status        String        // DRAFT, PARTIAL, PAID, CANCELLED
  totalAmount   Float         @default(0)
  taxAmount     Float         @default(0)
  amountPaid    Float         @default(0)
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  depotId       String
  depot         Depot         @relation(fields: [depotId], references: [id], onDelete: Cascade)
  lines         InvoiceLine[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model InvoiceLine {
  id        String  @id @default(uuid())
  quantity  Float
  unitPrice Float
  discount  Float   @default(0)
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}
